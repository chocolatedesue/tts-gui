import { Button, ComboBox, Slider, VerticalBox, HorizontalBox, TextEdit, Switch, Palette, LineEdit, GroupBox, GridBox, ScrollView } from "std-widgets.slint";

component NavItem inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active;
    callback clicked();
    height: 4.5rem;
    background: active ? Palette.accent-background : ta.has-hover ? Palette.control-background : transparent;
    animate background { duration: 150ms; }
    border-radius: 6px;
    ta := TouchArea { clicked => { root.clicked(); } mouse-cursor: pointer; }
    VerticalLayout {
        alignment: center;
        spacing: 4px;
        Image {
            source: icon;
            width: 24px;
            height: 24px;
            colorize: active ? Palette.accent-foreground : Palette.foreground;
            horizontal-alignment: center;
        }
        Text {
            text: label;
            font-size: 0.75rem;
            color: active ? Palette.accent-foreground : Palette.foreground;
            font-weight: active ? 700 : 400;
            horizontal-alignment: center;
        }
    }
}

component ParamRow inherits HorizontalLayout {
    in property <string> label;
    in-out property <float> param-value;
    in property <string> unit: "%";
    spacing: 8px;
    Text { text: label; vertical-alignment: center; min-width: 40px; }
    Slider { minimum: -50; maximum: 50; value <=> param-value; horizontal-stretch: 1; }
    Text {
        text: param-value >= 0 ? "+" + Math.round(param-value) + unit : Math.round(param-value) + unit;
        vertical-alignment: center; min-width: 50px;
    }
}

export component MainWindow inherits Window {
    title: "Edge TTS 语音合成";
    min-width: 700px;
    min-height: 500px;
    preferred-width: 920px;
    preferred-height: 640px;
    default-font-size: 15px;

    // State
    in-out property <int> current-page: 0;
    in-out property <bool> generating: false;
    in-out property <bool> has-audio: false;
    in-out property <bool> playing: false;
    in-out property <string> status: "就绪";

    // Synth page
    in-out property <string> cleaned-text: "";
    in-out property <bool> clean-enabled: true;
    in-out property <[string]> lang-list: ["全部"];
    in-out property <int> current-lang-index: 0;
    in-out property <int> current-gender-index: 0;
    in-out property <[string]> voice-display-list: [];
    in-out property <int> current-voice-index: 0;

    // Settings
    in-out property <string> api-url: "";
    in-out property <string> api-key: "";
    in-out property <string> api-model: "";
    in-out property <string> clean-prompt: "";
    in-out property <float> rate-value: 0;
    in-out property <float> pitch-value: 0;
    in-out property <float> volume-value: 0;
    in-out property <[string]> device-list: ["默认"];
    in-out property <int> current-device-index: 0;

    // Player bar
    in-out property <float> player-progress: 0;
    in-out property <string> player-current-time: "0:00";
    in-out property <string> player-total-time: "0:00";
    in-out property <float> player-volume: 80;
    in-out property <string> player-speed-label: "1x";

    // Toast
    in-out property <string> toast-message: "";
    in-out property <bool> toast-visible: false;
    in-out property <int> toast-type: 0;

    // Callbacks
    callback generate(string);
    callback play-audio();
    callback pause-audio();
    callback stop-audio();
    callback seek-audio(float);
    callback set-volume(float);
    callback cycle-speed();
    callback preview-voice();
    callback filter-changed(int, int);
    callback save-settings();
    callback dismiss-toast();

    VerticalLayout {
        HorizontalLayout {
            vertical-stretch: 1;

            // Sidebar
            VerticalLayout {
                width: 7.5rem;
                padding: 12px;
                spacing: 4px;
                Rectangle { height: 16px; }
                NavItem { icon: @image-url("icons/mic.svg"); label: "合成"; active: current-page == 0; clicked => { current-page = 0; } }
                NavItem { icon: @image-url("icons/settings.svg"); label: "设置"; active: current-page == 1; clicked => { current-page = 1; } }
                Rectangle { vertical-stretch: 1; }
                Text { text: status; font-size: 0.7rem; color: Palette.foreground.transparentize(0.5); wrap: word-wrap; horizontal-alignment: center; }
            }

            Rectangle { width: 1px; background: Palette.border; }

            // Content area
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                // Synth page
                if current-page == 0: VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    // Text panels
                    HorizontalLayout {
                        spacing: 12px;
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            HorizontalLayout {
                                height: 1.75rem;
                                Text { text: "原文"; font-size: 0.87rem; color: Palette.foreground.transparentize(0.4); vertical-alignment: center; }
                                Rectangle { horizontal-stretch: 1; }
                            }
                            input := TextEdit {
                                vertical-stretch: 1;
                                placeholder-text: "在此输入要合成的文本...";
                                wrap: word-wrap;
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            HorizontalLayout {
                                height: 1.75rem;
                                Text { text: "清洗后"; font-size: 0.87rem; color: Palette.foreground.transparentize(0.4); vertical-alignment: center; }
                                Rectangle { horizontal-stretch: 1; }
                                Text { text: "清洗"; font-size: 0.8rem; vertical-alignment: center; }
                                Switch { checked <=> clean-enabled; }
                            }
                            TextEdit {
                                vertical-stretch: 1;
                                text <=> cleaned-text;
                                placeholder-text: "清洗后的文本...";
                                wrap: word-wrap;
                                read-only: true;
                            }
                        }
                    }

                    // Voice selection row
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "语言"; vertical-alignment: center; min-width: 2.5rem; }
                        ComboBox {
                            model: lang-list;
                            current-index <=> current-lang-index;
                            selected => { filter-changed(current-lang-index, current-gender-index); }
                            horizontal-stretch: 1;
                        }
                        Text { text: "性别"; vertical-alignment: center; min-width: 2.5rem; }
                        ComboBox {
                            model: ["全部", "男", "女"];
                            current-index <=> current-gender-index;
                            selected => { filter-changed(current-lang-index, current-gender-index); }
                            min-width: 70px;
                        }
                        Text { text: "音色"; vertical-alignment: center; min-width: 2.5rem; }
                        ComboBox {
                            model: voice-display-list;
                            current-index <=> current-voice-index;
                            horizontal-stretch: 2;
                        }
                        Button { text: "试听"; enabled: !generating; clicked => { preview-voice(); } }
                    }

                    // Generate button
                    HorizontalLayout {
                        alignment: center;
                        Button { text: generating ? "生成中..." : "生成"; enabled: !generating; clicked => { generate(input.text); } min-width: 120px; primary: true; }
                    }
                }

                // Settings page
                if current-page == 1: ScrollView {
                    VerticalLayout {
                        padding: 12px;
                        spacing: 12px;

                        GroupBox {
                            title: "LLM 文本清洗";
                            GridLayout {
                                spacing: 8px;
                                padding: 4px;
                                Row {
                                    Text { text: "URL"; vertical-alignment: center; }
                                    LineEdit { text <=> api-url; }
                                }
                                Row {
                                    Text { text: "Key"; vertical-alignment: center; }
                                    LineEdit { text <=> api-key; }
                                }
                                Row {
                                    Text { text: "Model"; vertical-alignment: center; }
                                    LineEdit { text <=> api-model; }
                                }
                            }
                        }

                        GroupBox {
                            title: "清洗 Prompt";
                            TextEdit {
                                height: 80px;
                                text <=> clean-prompt;
                                wrap: word-wrap;
                            }
                        }

                        GroupBox {
                            title: "语音参数";
                            VerticalLayout {
                                spacing: 8px;
                                padding: 4px;
                                ParamRow { label: "语速"; param-value <=> rate-value; unit: "%"; }
                                ParamRow { label: "音调"; param-value <=> pitch-value; unit: "Hz"; }
                                ParamRow { label: "音量"; param-value <=> volume-value; unit: "%"; }
                            }
                        }

                        GroupBox {
                            title: "音频设备";
                            VerticalLayout {
                                padding: 4px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text { text: "设备"; vertical-alignment: center; min-width: 40px; }
                                    ComboBox {
                                        model: device-list;
                                        current-index <=> current-device-index;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            Button { text: "保存设置"; clicked => { save-settings(); } }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }

                // Toast notification
                if toast-visible: Rectangle {
                    x: parent.width - self.width - 12px;
                    y: 12px;
                    width: 240px;
                    height: 40px;
                    border-radius: 6px;
                    background: toast-type == 2 ? Colors.red.transparentize(0.15) : toast-type == 1 ? Colors.green.transparentize(0.15) : Palette.accent-background;
                    TouchArea { clicked => { dismiss-toast(); } }
                    Text {
                        text: toast-message;
                        color: white;
                        font-size: 0.82rem;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Bottom player bar
        Rectangle {
            height: 3rem;
            background: Palette.alternate-background;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                Button {
                    text: playing ? "⏸" : "▶";
                    enabled: has-audio;
                    clicked => { if (playing) { pause-audio(); } else { play-audio(); } }
                    max-width: 36px;
                }
                Button {
                    text: "⏹";
                    enabled: has-audio;
                    clicked => { stop-audio(); }
                    max-width: 36px;
                }
                Slider {
                    horizontal-stretch: 1;
                    minimum: 0;
                    maximum: 100;
                    value <=> player-progress;
                    enabled: has-audio;
                    changed(v) => { seek-audio(v); }
                }
                Text {
                    text: player-current-time + " / " + player-total-time;
                    font-size: 0.75rem;
                    vertical-alignment: center;
                    min-width: 80px;
                }
                Slider {
                    width: 80px;
                    minimum: 0;
                    maximum: 100;
                    value <=> player-volume;
                    enabled: has-audio;
                    changed(v) => { set-volume(v); }
                }
                Button {
                    text: player-speed-label;
                    enabled: has-audio;
                    clicked => { cycle-speed(); }
                    max-width: 40px;
                }
            }
        }
    }
}
